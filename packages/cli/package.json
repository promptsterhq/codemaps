{
  "name": "@codemaps/cli",
  "version": "0.1.0",
  "description": "Codemaps CLI \u2014 npx codemaps: index a repo, generate AGENTS.md, serve context to agents.",
  "type": "module",
  "bin": {
    "codemaps": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@codemaps/core": "workspace:*",
    "@codemaps/mcp": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "typescript": "^5.6.3"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/promptsterhq/codemaps.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/promptsterhq/codemaps#readme",
  "publishConfig": {
    "access": "public"
  }
}
